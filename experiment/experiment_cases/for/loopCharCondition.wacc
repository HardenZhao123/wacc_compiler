# Use a character as a loop condition. Enter the loop once only, then exit the loop.

# Output:
# Change c
# Should print "Change c" once before.
#

# Program:

begin
  char c = '\0' ;

  for (skip, c == '\0', skip)
    c = 'a' ;
    println "Change c"
  done ;

  println "Should print \"Change c\" once before."
end