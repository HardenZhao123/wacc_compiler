# function overloading with general exception handling

# Output:
# caught general exception:
# negative input is not allowed
#

# Program:

begin
  int risky(int x) is
    if x < 0 then
      throw Exception("negative input is not allowed")
    else
      return x * 2
    fi
  end

  int risky(bool ok) is
    if ok then
      return 42
    else
      throw Exception("boolean overload rejected")
    fi
  end

  try
    int y = call risky(-1);
    println y
  catch Exception err do
    println "caught general exception:";
    println err
  done
end